# Copy to .env and fill in values. Do not commit .env with secrets.
#
# OpenAI-compatible API (used by app/llm_router.py and evaluation scripts)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45

# Optional: load large datasets without materializing CSV copies first
# INSURANCE_SOURCE_CSV=/path/to/insurance.csv
# YELLOW_TRIPDATA_PARQUET=/path/to/yellow_tripdata_2026-01.parquet
# YELLOW_TRIPDATA_MAX_ROWS=100000
# ONLINE_RETAIL_II_ZIP=/path/to/online_retail_II.csv.zip
# ONLINE_RETAIL_MAX_ROWS=120000
